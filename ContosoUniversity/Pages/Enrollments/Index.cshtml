@page
@model ContosoUniversity.Pages.Enrollments.IndexModel
@{
    ViewData["Title"] = "Enrollments";
}
<form asp-page="./Index" method="get">


<div class="index-tools">
    <div class="index-left-side">
        <h1>Enrollments</h1>
        <div class="create-button">
            <a asp-page="Create" class="btn btn-primary">Create New</a>
        </div>
    </div>
    

    <div>
        <label for="items-per-page">Количество записей на странице:</label>
            <select id="items-per-page" name="pageSize" onchange="this.form.submit()">

                @if (Model.PageSize == 3)
                {
                    <option value="3" selected>3</option>
                }
                else
                {
                    <option value="3">3</option>
                }

                @if (Model.PageSize == 5 || Model.PageSize == null)
                {
                    <option value="5" selected>5</option>
                }
                else
                {
                    <option value="5">5</option>
                }

                @if (Model.PageSize == 8)
                {
                    <option value="8" selected>8</option>
                }
                else
                {
                    <option value="8">8</option>
                }

                @if (Model.PageSize == 10)
                {
                    <option value="10" selected>10</option>
                }
                else
                {
                    <option value="10">10</option>
                }

            </select>
        </div>

        <div>
            <label for="SearchString">Поиск по студенту или курсу:</label>
            <input type="text" name="SearchString" id="SearchString" value="@Model.CurrentFilter" />
            <input type="submit" value="Search" class="btn btn-primary" />
            <a asp-page="./Index">Сбросить</a>
        </div>
</div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>
                <a asp-page="./Index"
                   asp-route-sortOrder="@Model.StudentSort"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-currentFilter="@Model.CurrentFilter">
                    @Html.DisplayNameFor(model => model.PLEnrollments.FirstOrDefault().Student.FullName)
                </a>
            </th>
            <th>
                <a asp-page="./Index"
                   asp-route-sortOrder="@Model.CourseSort"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-currentFilter="@Model.CurrentFilter">
                    @Html.DisplayNameFor(model => model.PLEnrollments.FirstOrDefault().Course.Title)
                </a>
            </th>
            <th>
                <a asp-page="./Index"
                   asp-route-sortOrder="@Model.GradeSort"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-currentFilter="@Model.CurrentFilter">
                    @Html.DisplayNameFor(model => model.PLEnrollments.FirstOrDefault().Grade)
                </a>
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.PLEnrollments)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Student.FullName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Course.Title)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Grade)
                </td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.EnrollmentID">Edit</a> |
                    <a asp-page="./Details" asp-route-id="@item.EnrollmentID">Details</a> |
                    <a asp-page="./Delete" asp-route-id="@item.EnrollmentID">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@{
    string prevDisabled = Model.PLEnrollments.HasPreviousPage ? "" : "disabled";
    string nextDisabled = Model.PLEnrollments.HasNextPage ? "" : "disabled";
}

<div class="pagination">
    <a asp-page="./Index"
       asp-route-sortOrder="@Model.CurrentSort"
       asp-route-pageIndex="@(Model.PLEnrollments.PageIndex - 1)"
       asp-route-currentFilter="@Model.CurrentFilter"
       asp-route-pageSize="@Model.PageSize"
       class="btn btn-primary @prevDisabled">
        Prev
    </a>
    <a asp-page="./Index"
       asp-route-sortOrder="@Model.CurrentSort"
       asp-route-pageIndex="@(Model.PLEnrollments.PageIndex + 1)"
       asp-route-currentFilter="@Model.CurrentFilter"
       asp-route-pageSize="@Model.PageSize"
       class="btn btn-primary @nextDisabled">
        Next
    </a>
</div>
